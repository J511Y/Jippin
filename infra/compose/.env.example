# =============================================================================
# Jippin — docker compose 환경변수 자리표시자
# Originally CMP-530; APP_ENV ↔ Neon branch mapping shape: CMP-538.
# -----------------------------------------------------------------------------
# 사용법:
#   cp infra/compose/.env.example infra/compose/.env
#   # 그 다음 실제 값으로 채워 넣는다. .env 는 .gitignore 차단되어 커밋되지 않는다.
#
# 봉인:
#   AGENTS.md §4.4 — 모든 시크릿은 .env 로컬에서만 읽고, 코드/이미지에 박지 않는다.
#   AGENTS.md §4.4 — APP_ENV ↔ Neon 브랜치 매핑 봉인. 본 .env 는 production-shape.
#   docker-compose.yml 의 ${DATABASE_URL:?...} 가드가 부재 시 부팅을 차단한다.
#
# 본 자리표시자는 production 형상(`main` 브랜치)을 가정한다.
# 다른 APP_ENV 에서는 host prefix 만 갈아끼운다
# (`ep-staging-…` / `ep-dev-…` / `ep-local-…` — `local` 은 CMP-544 신규).
# 자세한 매핑은 docs/runbooks/neon-branches.md.
# =============================================================================

# --- APP_ENV — production-shape 자리표시자 -----------------------------------
# 허용 값: development | test | staging | production
# (apps/api/src/config.py::ALLOWED_APP_ENVS 가 봉인. 그 외 값은 부팅 차단.)
APP_ENV=production

# --- Neon Postgres (외부 서비스, 컨테이너로 띄우지 않음) ----------------------
# sslmode=require 는 필수. Neon 은 TLS 없는 연결을 거부.
# host prefix `ep-main-…` 가 production(`main`) 브랜치 신호.
#
# 비-풀러(non-pooler) — 트랜잭션·DDL·마이그레이션용.
DATABASE_URL=postgresql://USER:PASSWORD@ep-main-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# pgbouncer 풀러 — 어플리케이션 단의 일반 SELECT/INSERT.
DATABASE_POOL_URL=postgresql://USER:PASSWORD@ep-main-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- Redis (compose 내부 redis 서비스. URL 은 호스트가 아닌 서비스명) ----------
REDIS_URL=redis://redis:6379/0

# --- 포트 (compose 가 직접 읽지는 않음. 외부 매핑은 docker-compose.yml 에 하드코딩) ---
# 본 값은 README/스크립트가 참조할 수 있는 참고용 자리표시자다.
WEB_PORT=3000
API_PORT=8000

# --- Web BFF / Browser → API 라우팅 -----------------------------------------
# Browser 호출은 같은 origin 의 /api 로 보내고, Next rewrite / Route Handler 가
# 컨테이너 네트워크의 API_INTERNAL_BASE_URL 로 전달한다. 이렇게 해야
# host-only jippin_session 쿠키가 web/API 호출 모두에 같은 scope 로 붙는다.
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_BASE_URL=http://api:8000

# --- Supabase Auth (web SSR/BFF + api bridge) -------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-publishable-key>
SUPABASE_FLOW_COOKIE_SECRET=<random-flow-cookie-secret>
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
SUPABASE_JWT_AUDIENCE=authenticated

# -----------------------------------------------------------------------------
# AUTH — CMP-557 / CMP-558 / ADR-0003.
#
# docker-compose 의 api.environment 가 본 변수들을 컨테이너에 주입한다
# (`infra/compose/docker-compose.yml` 의 api 서비스 environment 절 참조).
# 변수명만 자리표시자로 둔다. 실값은 로컬 `.env` 또는 운영 시크릿 매니저에서
# 채운다. 정본 정의·해설은 `apps/api/.env.example` AUTH 절을 참조.
# -----------------------------------------------------------------------------

# Kakao OAuth
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/callback/kakao

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/google

# Naver OAuth
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/naver

# OAuth state store (Redis). 컨테이너 내부 redis 서비스 + DB index 1.
OAUTH_STATE_REDIS_URL=redis://redis:6379/1
OAUTH_STATE_TTL_SECONDS=600

# JWT (Access 1h / Refresh 7d, security-policy.md POL-AUTH-002 와 정합).
AUTH_JWT_SECRET=
AUTH_JWT_ALG=HS256
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_JWT_REFRESH_TTL_SECONDS=604800

# 익명 세션 (비회원 사전검토). 헤더명 정본.
ANON_SESSION_HEADER=x-jippin-anon-id
ANON_SESSION_TTL_DAYS=30

# OAuth callback redirects. API 가 callback 처리 후 302.
FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/auth/success
FRONTEND_AUTH_FAILURE_URL=http://localhost:3000/auth/failure
FRONTEND_AUTH_TERMS_URL=http://localhost:3000/auth/terms
