# 집핀(Jippin) — .editorconfig
# CEO 브리프 §2 D5 / ADR-0001 §9 봉인.
# UTF-8 / LF / 끝에 newline / trailing whitespace 제거.
# 들여쓰기: Python 4-space, TS/JS/JSON/YAML/MD 2-space.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# -----------------------------------------------------------------------------
# Python — apps/api, tooling/, packages/contracts/python/
# -----------------------------------------------------------------------------
[*.{py,pyi}]
indent_size = 4
max_line_length = 100

# -----------------------------------------------------------------------------
# TypeScript / JavaScript / JSX — apps/web/, packages/contracts/ts/
# -----------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

# -----------------------------------------------------------------------------
# JSON / YAML — 설정 파일, JSON Schema 정본
# -----------------------------------------------------------------------------
[*.{json,jsonc,yaml,yml}]
indent_size = 2

# -----------------------------------------------------------------------------
# 마크다운 — trailing whitespace 는 두 개일 때 줄바꿈 의미. 보존.
# -----------------------------------------------------------------------------
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# Shell / Makefile — Makefile은 탭 필수.
# -----------------------------------------------------------------------------
[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

# -----------------------------------------------------------------------------
# Docker / nginx 설정
# -----------------------------------------------------------------------------
[{Dockerfile,Dockerfile.*,*.dockerfile}]
indent_size = 2

[*.{conf,nginx}]
indent_size = 2

# -----------------------------------------------------------------------------
# 잠금 파일 / 생성물 — 포매팅 적용 X
# -----------------------------------------------------------------------------
[{pnpm-lock.yaml,package-lock.json,yarn.lock,uv.lock,poetry.lock}]
indent_size = unset
indent_style = unset
trim_trailing_whitespace = false
insert_final_newline = unset
