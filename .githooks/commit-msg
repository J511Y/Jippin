#!/usr/bin/env sh
# 집핀(Jippin) commit-msg 훅 — gitmoji prefix 강제.
# AGENTS.md §4.1 / docs/CONTRIBUTING.md §2.1.
#
# 활성화:
#   git config core.hooksPath .githooks
#
# CI(.github/workflows/ci.yml gitmoji-validate job) 와 동일 규칙.

set -e

# Python 3 가 PATH 에 있어야 한다 (.python-version = 3.13).
# Windows 의 "Microsoft Store python stub" 은 `command -v` 에는 잡히지만
# 실제 실행 시 exit 49 + "Python" 만 출력하므로, 후보별로 --version 응답을
# 검증하여 실 인터프리터를 고른다.
PY=""
for candidate in python3 python py; do
  if command -v "$candidate" >/dev/null 2>&1; then
    VER_OUTPUT="$("$candidate" --version 2>&1 || true)"
    case "$VER_OUTPUT" in
      "Python "[0-9]*) PY="$candidate"; break ;;
    esac
  fi
done

if [ -z "$PY" ]; then
  echo "[commit-msg] python 미설치 — gitmoji 검증을 건너뛴다. (CI 에서는 강제됨)" >&2
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
"$PY" "$REPO_ROOT/tooling/validate_commit_msg.py" "$1"
