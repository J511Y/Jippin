# apps/admin 환경변수 예시 (커밋 금지: 실제 값은 .env.local 또는 배포 환경 시크릿)
# CMP-DIRECT — 관리자 사이트는 main Supabase 프로젝트(Jippin)를 직접 사용한다.

# Supabase main 프로젝트. SSR cookie adapter / proxy 게이트가 읽는다. 미설정 시 즉시 throw.
NEXT_PUBLIC_SUPABASE_URL=https://ywtfmiawlramqqcfwsiv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# 서버 전용 — Route Handler / Server Action 에서 RLS 우회 데이터 접근에 사용.
# requireAdminUser 게이트 통과 후에만 사용한다. 절대 NEXT_PUBLIC_ 금지.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
