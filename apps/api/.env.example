# apps/api — local environment example.
# Originally CMP-528; APP_ENV ↔ DB branch mapping sealed by CMP-538/CMP-574.
# The repo-wide example lives at /.env.example; this file documents the
# api-app-specific keys and the psycopg3 URL scheme used by src/db.py.

# -----------------------------------------------------------------------------
# APP_ENV — sealed enum. Validator in src/config.py blocks any other value.
#
#   development : Supabase branch `development`
#   test        : Supabase preview/pr-N branch
#   staging     : Supabase branch `staging`
#   production  : Supabase branch `production`
#
# The APP_ENV enum is NOT extended (CMP-538 sealed); the branch is selected
# only via the DATABASE_URL / DATABASE_POOL_URL value (12-factor).
#
# See docs/runbooks/supabase-branching.md for branch creation and operations.
# Mapping sealed in AGENTS.md §4.4 (footnote added by CMP-544).
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
REQUEST_ID_HEADER=x-request-id

# -----------------------------------------------------------------------------
# Derivation primitives (CMP-DIRECT). Most per-environment URLs are pure
# functions of {Supabase project ref, public web origin}. Set these two and
# src/config.py::_derive_from_primitives fills the rest, so a deployed
# environment (e.g. Fly) needs ~half the secrets. Any explicit value below
# still wins (escape hatch).
#
#   SUPABASE_REF      -> SUPABASE_JWKS_URL, SUPABASE_JWT_ISSUER
#   PUBLIC_WEB_ORIGIN -> FRONTEND_AUTH_{SUCCESS,FAILURE,TERMS}_URL,
#                        CORS_ALLOW_ORIGINS
#
# Local note: this file is copied to `.env` for local runs, so LEAVE
# PUBLIC_WEB_ORIGIN BLANK (or set http://localhost:3000). A non-local value
# here would derive CORS + auth redirects pointing away from localhost and
# break the local web app. PUBLIC_WEB_ORIGIN must be a bare origin
# (scheme + host[:port], no path).
#
# DATABASE_*_URL is deliberately NOT derived: it carries the DB password and the
# pooler shard host (aws-1-…) is not a pure function of the ref — set it whole.
# -----------------------------------------------------------------------------
SUPABASE_REF=
PUBLIC_WEB_ORIGIN=

# Test-mode short-circuit for /healthz (skips real DB SELECT 1).
TEST_MODE=false

# -----------------------------------------------------------------------------
# Supabase Postgres — psycopg3 async driver (postgresql+psycopg://).
#
# Rules (do not commit real values):
# - sslmode=require is MANDATORY on every URL.
# - DATABASE_POOL_URL : Supabase pooler endpoint (port 6543). Request-path.
# - DATABASE_URL      : Supabase direct endpoint (port 5432). DDL / long tx.
#
# Patterns by APP_ENV (placeholders — fill from Supabase Dashboard > Connect):
#
#   DATABASE_POOL_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
#   DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_POOL_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# CORS — JSON list per pydantic-settings. Derived from PUBLIC_WEB_ORIGIN when
# unset; set explicitly to override (e.g. multiple origins). Default ["*"].
# CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# 상담 리드(consultation leads) — CMP-DIRECT.
# -----------------------------------------------------------------------------
# 도로명주소 API 승인키 (business.juso.go.kr 에서 발급, 운영 도메인 등록 키).
# 미설정 시 GET /leads/address/search 가 503 (JUSO_CONFM_KEY_MISSING) 을 반환한다.
JUSO_CONFM_KEY=
# (옵션) juso 검색 API 엔드포인트 override. 기본값은 addrLinkApi.do.
# JUSO_API_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
# 평면도 첨부 Supabase Storage 버킷명 (migration 0009 의 lead-floorplans 와 일치).
LEAD_FLOORPLAN_BUCKET=lead-floorplans

# -----------------------------------------------------------------------------
# AUTH — CMP-557 (CEO 정책) / CMP-558 (docs 트랙 A) / ADR-0003.
#
# Variable names only. Leave real values blank; populate per-environment in
# the deployed .env (never commit secrets — AGENTS.md §4.4 / §5.8).
#
# Provider IDs are managed by Supabase Auth identities. Self-password signup is
# permanently forbidden. Email-based auto-merge across providers is forbidden.
# Kakao Sync terms consent is stored with source='kakao_sync' (no internal
# terms screen). Google/Naver MUST pass through the internal terms screen
# and store source='internal_signup'.
# -----------------------------------------------------------------------------

# --- Kakao OAuth (Kakao 로그인 API v2, Authorization Code Flow) ---
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/callback/kakao

# --- Google OAuth (Google Identity Services / OpenID Connect) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/google

# --- Naver OAuth (Naver 로그인 API, Authorization Code Flow) ---
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/naver

# --- OAuth state store (Redis, TTL <= 600s) ---
# Re-uses the shared Redis container from infra/compose. Choose a dedicated
# DB index or key prefix per environment to avoid collisions.
OAUTH_STATE_REDIS_URL=redis://localhost:6379/1
OAUTH_STATE_TTL_SECONDS=600
# CMP-561 canonical TTL key; OAUTH_STATE_TTL_SECONDS remains accepted for
# compatibility with CMP-558 docs.
AUTH_OAUTH_STATE_TTL_SECONDS=600

# --- JWT (Access / Refresh) ---
# Generate a strong random secret per environment. Rotate via the auth runbook.
# Refresh TTL canonical = 7 days (604800s), matching docs/runbooks/security-policy.md
# POL-AUTH-002. Functional spec v1.0 (30d) and an earlier ADR draft value (14d) are
# tracked as CFLT-006 in docs/명세서-모순.md and superseded by this value.
AUTH_JWT_SECRET=
AUTH_JWT_ALG=HS256
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_JWT_REFRESH_TTL_SECONDS=604800

# --- Supabase session bridge ---
# Used by POST /auth/supabase/session to verify Supabase PKCE access tokens
# before minting the backend jippin_session cookie.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# --- Legacy auth redirect compatibility ---
# CMP-604 moved OAuth code exchange to Supabase Auth + the web /auth/callback
# route. FastAPI /auth/callback/{provider} is legacy and returns 410. These URLs
# remain only for older compatibility/error paths that still need a frontend
# destination; do not use them as provider redirect URIs.
# Derived from PUBLIC_WEB_ORIGIN when unset; set explicitly only to override a
# single one. Default falls back to localhost:3000 (local dev).
# FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/auth/success
# FRONTEND_AUTH_FAILURE_URL=http://localhost:3000/auth/failure
# FRONTEND_AUTH_TERMS_URL=http://localhost:3000/auth/terms

# -----------------------------------------------------------------------------
# Supabase session bridge (CMP-595). POST /auth/supabase/session verifies a
# Supabase Auth access token via JWKS and mints the existing jippin_session
# cookie. Variable names only — fill from the Supabase project dashboard:
#   - SUPABASE_JWT_ISSUER : https://<project-ref>.supabase.co/auth/v1
#   - SUPABASE_JWKS_URL   : https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#   - SUPABASE_JWT_AUDIENCE : Supabase default `authenticated`. Override only
#                             if the project uses a non-default audience.
# Supabase JWT `sub` is the user id. public.users is an app profile table keyed
# by auth.users.id; no public auth_identities mapping table is used.
#
# ISSUER + JWKS_URL are derived from SUPABASE_REF when unset (see top of file);
# leave blank and set SUPABASE_REF instead, or fill these to override.
# -----------------------------------------------------------------------------
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# -----------------------------------------------------------------------------
# 이메일/비밀번호 회원가입 — Supabase Auth GoTrue admin API (CMP-DIRECT).
#
# 비밀번호는 auth.users 가 단독 관리한다(우리 테이블에 password 컬럼 없음 — AGENTS §4.7 #3).
# service_role 키는 백엔드만 보유한다 — 절대 web(NEXT_PUBLIC) / 커밋 / PR / 스크린샷에
# 노출하지 말 것. createUser / updateUser(password) / deleteUser 에 사용한다.
#   - SUPABASE_URL : https://<project-ref>.supabase.co (admin base 파생용 보조;
#                    SUPABASE_JWT_ISSUER 가 있으면 그쪽을 우선 사용)
#   - SUPABASE_SERVICE_ROLE_KEY : Supabase 대시보드 > Project Settings > API > service_role
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# 비밀번호 정책(Supabase 콘솔 설정과 정합: 최소 6자, 영문+숫자). 변경 시 콘솔도 함께 조정.
SIGNUP_MIN_PASSWORD_LENGTH=6
# 가입 시 이메일 자동 확인(휴대폰 인증만으로 confirmed 처리). true 는 이메일 소유를 검증하지
# 않아 squatting 위험이 있다. 강화하려면 false + Supabase SMTP/이메일 확인 플로우 필요
# (단, 가입 직후 자동 로그인은 불가).
SIGNUP_AUTO_CONFIRM_EMAIL=true

# -----------------------------------------------------------------------------
# SOLAPI 문자(SMS) 본인인증 — CMP-DIRECT.
#
# 휴대폰 6자리 인증번호 발송에 사용한다. 발신번호(SOLAPI_SENDER_PHONE)는 SOLAPI 콘솔에
# 사전 등록(발신번호 등록)된 번호여야 실제 발송된다. 키/시크릿/발신번호 미설정 시
# POST /auth/phone/send-code 가 503(SMS_PROVIDER_NOT_CONFIGURED) 을 반환한다.
# 발송은 공식 SOLAPI Python SDK(`solapi`)로 처리한다.
#   Python SDK 문서: https://solapi.com/developers/sdk/python
# -----------------------------------------------------------------------------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
# (옵션) SOLAPI API 베이스 URL override. 기본값 https://api.solapi.com.
# SOLAPI_API_URL=https://api.solapi.com

# --- 휴대폰 OTP 정책 (Redis 저장, OAuth state store 와 같은 Redis 공유) ---
PHONE_OTP_CODE_LENGTH=6
PHONE_OTP_TTL_SECONDS=180
PHONE_OTP_TOKEN_TTL_SECONDS=600
PHONE_OTP_MAX_ATTEMPTS=5
PHONE_OTP_RESEND_COOLDOWN_SECONDS=30
PHONE_OTP_DAILY_SEND_LIMIT=10
# 번호 회전 남용/비용 가드 — 발송 전 IP·글로벌 시간당 한도(번호 단위 한도와 별개).
PHONE_OTP_IP_HOURLY_LIMIT=20
PHONE_OTP_GLOBAL_HOURLY_LIMIT=300
# IP 한도의 신뢰 출처 헤더. 프록시(Fly)가 설정하는 헤더만 신뢰한다(클라이언트 위조 가능한
# X-Forwarded-For 미사용). 다른 프록시면 그 신뢰 헤더로 바꾸고, 직접 노출이면 빈 값으로 둔다.
PHONE_OTP_TRUSTED_IP_HEADER=fly-client-ip

# -----------------------------------------------------------------------------
# Supabase Auth PoC — CMP-576 only.
#
# These variables are intentionally separate from the current first-party OAuth
# stack. Do not populate real project URLs, publishable keys, OAuth secrets, or
# service-role keys in git, issues, PR bodies, or screenshots.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
SUPABASE_AUTH_MANUAL_LINKING_REQUIRED=true
SUPABASE_AUTH_GOOGLE_PROVIDER=google
SUPABASE_AUTH_KAKAO_PROVIDER=kakao
SUPABASE_AUTH_NAVER_PROVIDER=custom:naver
SUPABASE_JWT_ALGORITHMS=RS256,ES256
