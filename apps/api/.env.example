# apps/api — local environment example.
# Originally CMP-528; APP_ENV ↔ Neon branch mapping sealed by CMP-538.
# The repo-wide example lives at /.env.example; this file documents the
# api-app-specific keys and the psycopg3 URL scheme used by src/db.py.

# -----------------------------------------------------------------------------
# APP_ENV — sealed enum. Validator in src/config.py blocks any other value.
#
#   development : long-lived Neon branch  `local`  (workstation; CMP-544)
#                 OR                       `dev`    (CI + `development` GitHub
#                                                    Environment deploy)
#   test        : Neon branch `dev` OR a PR-ephemeral branch  (CI / unit tests)
#   staging     : long-lived Neon branch  `staging` (QA / pre-prod)
#   production  : long-lived Neon branch  `main`    (live traffic)
#
# Local development = `APP_ENV=development` + `local` Neon branch URL.
# CI / `development` environment deploy keeps `APP_ENV=development` + `dev`
# Neon branch URL. The APP_ENV enum is NOT extended (CMP-538 sealed); the
# branch is selected only via the DATABASE_URL host segment (12-factor).
#
# See docs/runbooks/neon-branches.md for branch creation and rotation.
# Mapping sealed in AGENTS.md §4.4 (footnote added by CMP-544).
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
REQUEST_ID_HEADER=x-request-id

# Test-mode short-circuit for /healthz (skips real DB SELECT 1).
TEST_MODE=false

# -----------------------------------------------------------------------------
# Neon Postgres — psycopg3 async driver (postgresql+psycopg://).
#
# Rules (do not commit real values):
# - sslmode=require is MANDATORY on every URL (Neon rejects non-TLS).
# - DATABASE_POOL_URL : pooler endpoint (host has `-pooler`). Request-path.
# - DATABASE_URL      : non-pooler endpoint. Alembic migrations / long tx.
# - Per APP_ENV, replace the host segment with the matching Neon branch
#   endpoint. The branch label is encoded in the Neon-assigned host prefix
#   (e.g. `ep-local-…`, `ep-dev-…`, `ep-staging-…`, `ep-main-…`); see
#   neon-branches runbook.
#
# Patterns by APP_ENV (placeholders — fill from Neon Console > Connect):
#
#   development (local workstation) → branch `local`  (CMP-544 default)
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-local-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-local-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   development (CI + `development` GitHub Environment deploy) → branch `dev`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   test → branch `dev` (CI) or per-PR ephemeral branch (CMP-536 자식 C)
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   staging → branch `staging`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-staging-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-staging-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   production → branch `main`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-main-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-main-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# -----------------------------------------------------------------------------
# Local development default: APP_ENV=development + `local` Neon branch URL.
DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-local-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-local-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# CORS — JSON list per pydantic-settings. Tighten in non-dev environments.
# CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# AUTH — CMP-557 (CEO 정책) / CMP-558 (docs 트랙 A) / ADR-0003.
#
# Variable names only. Leave real values blank; populate per-environment in
# the deployed .env (never commit secrets — AGENTS.md §4.4 / §5.8).
#
# Provider IDs are sealed to (google, naver, kakao) by PG ENUM
# `external_sso_provider`. Self-password signup is permanently forbidden.
# Email-based auto-merge across providers is forbidden — separate user rows.
# Kakao Sync terms consent is stored with source='kakao_sync' (no internal
# terms screen). Google/Naver MUST pass through the internal terms screen
# and store source='internal_signup'.
# -----------------------------------------------------------------------------

# --- Kakao OAuth (Kakao 로그인 API v2, Authorization Code Flow) ---
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/callback/kakao

# --- Google OAuth (Google Identity Services / OpenID Connect) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/google

# --- Naver OAuth (Naver 로그인 API, Authorization Code Flow) ---
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/naver

# --- OAuth state store (Redis, TTL <= 600s) ---
# Re-uses the shared Redis container from infra/compose. Choose a dedicated
# DB index or key prefix per environment to avoid collisions.
OAUTH_STATE_REDIS_URL=redis://localhost:6379/1
OAUTH_STATE_TTL_SECONDS=600
# CMP-561 canonical TTL key; OAUTH_STATE_TTL_SECONDS remains accepted for
# compatibility with CMP-558 docs.
AUTH_OAUTH_STATE_TTL_SECONDS=600

# --- JWT (Access / Refresh) ---
# Generate a strong random secret per environment. Rotate via the auth runbook.
# Refresh TTL canonical = 7 days (604800s), matching docs/runbooks/security-policy.md
# POL-AUTH-002. Functional spec v1.0 (30d) and an earlier ADR draft value (14d) are
# tracked as CFLT-006 in docs/명세서-모순.md and superseded by this value.
AUTH_JWT_SECRET=
AUTH_JWT_ALG=HS256
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_JWT_REFRESH_TTL_SECONDS=604800

# --- Supabase session bridge ---
# Used by POST /auth/supabase/session to verify Supabase PKCE access tokens
# before minting the backend jippin_session cookie.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# --- Anonymous session (비회원 사전검토) ---
# Server-issued UUID v4 stored in the browser as
# localStorage.jippin_anonymous_user_id. Backend reads it from a request
# header (default: x-jippin-anon-id) and tracks it in `anonymous_users`.
ANON_SESSION_HEADER=x-jippin-anon-id
ANON_SESSION_TTL_DAYS=30

# --- OAuth callback redirects ---
# The API owns the OAuth callback at /auth/callback/{provider}; after JWT issuance
# it 302-redirects to the success URL on the user-facing frontend, or to the
# failure URL with a query-string reason on error. These are the canonical
# variables; apps/web/.env.example carries the same names as a SPA-facing aid,
# but apps/api/.env.example is the source of truth for the redirect targets.
FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/auth/success
FRONTEND_AUTH_FAILURE_URL=http://localhost:3000/auth/failure
FRONTEND_AUTH_TERMS_URL=http://localhost:3000/auth/terms

# -----------------------------------------------------------------------------
# Supabase Auth PoC — CMP-576 only.
#
# These variables are intentionally separate from the current first-party OAuth
# stack. Do not populate real project URLs, publishable keys, OAuth secrets, or
# service-role keys in git, issues, PR bodies, or screenshots.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
SUPABASE_AUTH_MANUAL_LINKING_REQUIRED=true
SUPABASE_AUTH_GOOGLE_PROVIDER=google
SUPABASE_AUTH_KAKAO_PROVIDER=kakao
SUPABASE_AUTH_NAVER_PROVIDER=custom:naver
SUPABASE_JWT_ALGORITHMS=RS256,ES256
