# apps/api — local environment example.
# Originally CMP-528; APP_ENV ↔ Neon branch mapping sealed by CMP-538.
# The repo-wide example lives at /.env.example; this file documents the
# api-app-specific keys and the psycopg3 URL scheme used by src/db.py.

# -----------------------------------------------------------------------------
# APP_ENV — sealed enum. Validator in src/config.py blocks any other value.
#
#   development : long-lived shared Neon branch  `dev`        (local devs)
#   test        : Neon branch `dev` OR a PR-ephemeral branch  (CI / unit tests)
#   staging     : long-lived Neon branch         `staging`    (QA / pre-prod)
#   production  : long-lived Neon branch         `main`       (live traffic)
#
# See docs/runbooks/neon-branches.md for branch creation and rotation.
# Mapping sealed in AGENTS.md §4.4.
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
REQUEST_ID_HEADER=x-request-id

# Test-mode short-circuit for /healthz (skips real DB SELECT 1).
TEST_MODE=false

# -----------------------------------------------------------------------------
# Neon Postgres — psycopg3 async driver (postgresql+psycopg://).
#
# Rules (do not commit real values):
# - sslmode=require is MANDATORY on every URL (Neon rejects non-TLS).
# - DATABASE_POOL_URL : pooler endpoint (host has `-pooler`). Request-path.
# - DATABASE_URL      : non-pooler endpoint. Alembic migrations / long tx.
# - Per APP_ENV, replace the host segment with the matching Neon branch
#   endpoint. The branch label is encoded in the Neon-assigned host prefix
#   (e.g. `ep-dev-…`, `ep-staging-…`, `ep-main-…`); see neon-branches runbook.
#
# Patterns by APP_ENV (placeholders — fill from Neon Console > Connect):
#
#   development → branch `dev`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   test → branch `dev` (CI) or per-PR ephemeral branch (CMP-536 자식 C)
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-dev-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   staging → branch `staging`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-staging-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-staging-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
#   production → branch `main`
#     DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-main-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#     DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-main-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_POOL_URL=postgresql+psycopg://USER:PASSWORD@ep-EXAMPLE-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-EXAMPLE.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# CORS — JSON list per pydantic-settings. Tighten in non-dev environments.
# CORS_ALLOW_ORIGINS=["http://localhost:3000"]
