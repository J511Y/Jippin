# apps/web 환경변수 예시 (커밋 금지: 실제 값은 .env.local 또는 운영 시크릿 매니저)
# ADR-0001 §9 / AGENTS.md §4.4 봉인.

# 백엔드 API 베이스 URL (브라우저에서 직접 호출하므로 NEXT_PUBLIC_ prefix).
# 로컬 docker-compose: http://localhost:8000
# 프리뷰/운영: 배포 환경별 URL로 치환.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 옵션: 클라이언트 로깅 레벨 (debug | info | warn | error).
NEXT_PUBLIC_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# AUTH redirects — CMP-557 / CMP-558 / ADR-0003.
# OAuth 콜백 처리 후 프론트엔드가 라우팅할 성공·실패 경로. 변수명만 둔다.
# 운영 환경에서는 배포 도메인의 절대 URL 또는 상대 경로로 치환.
# -----------------------------------------------------------------------------
FRONTEND_AUTH_SUCCESS_URL=/auth/success
FRONTEND_AUTH_FAILURE_URL=/auth/failure
