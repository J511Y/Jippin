# apps/web 환경변수 예시 (커밋 금지: 실제 값은 .env.local 또는 운영 시크릿 매니저)
# ADR-0001 §9 / AGENTS.md §4.4 봉인.

# 백엔드 API 베이스 URL (브라우저에서 직접 호출하므로 NEXT_PUBLIC_ prefix).
# 로컬 docker-compose: http://localhost:8000
# 프리뷰/운영: 배포 환경별 URL로 치환.
# Browser-facing API base. Use `/api` behind the same-origin reverse proxy;
# use `http://localhost:8000` only for direct local dev without the proxy.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side Route Handlers / Next rewrites can use the private compose host.
API_INTERNAL_BASE_URL=http://localhost:8000

# 옵션: 클라이언트 로깅 레벨 (debug | info | warn | error).
NEXT_PUBLIC_LOG_LEVEL=info

# 옵션: Google Tag Manager 컨테이너 ID. 미설정 시 코드 기본값(GTM-TQN3DM5W)을 사용.
# GA4 등 실제 태그는 GTM 컨테이너 안에서 관리한다.
# 프리뷰/스테이징 컨테이너를 분리할 때만 덮어쓴다.
# NEXT_PUBLIC_GTM_ID=GTM-TQN3DM5W

# -----------------------------------------------------------------------------
# 상담 리드 평면도 첨부 — Supabase Storage S3 자격증명 (CMP-DIRECT / ADR-0007).
#
# 서버 전용(NEXT_PUBLIC_ 아님). Route Handler `POST /leads/upload-url` 가 presigned
# PUT URL 발급에 사용한다. Vercel 에 환경별(production/development)로 분리 주입한다.
# 절대 커밋 금지 — 값은 Supabase 프로젝트별 S3 access keys 발급분.
#   S3_ENDPOINT : https://<project-ref>.storage.supabase.co/storage/v1/s3
#   S3_REGION   : 예) ap-northeast-2
# -----------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# (옵션) 버킷명. 미설정 시 'lead-floorplans' (migration 0009 와 일치).
# LEAD_FLOORPLAN_BUCKET=lead-floorplans

# -----------------------------------------------------------------------------
# 도로명주소 팝업 승인키 — 상담 신청 폼 주소 검색(business.juso.go.kr 팝업 방식).
#
# 백엔드 REST 승인키(`apps/api` 의 JUSO_CONFM_KEY)와 **별개** 다 — juso 콘솔에서
# "팝업" 용도로 발급하고 운영 도메인(jippin.ai)을 등록한 키를 주입한다. 클라이언트
# form 에 실려 팝업으로 전송되므로 NEXT_PUBLIC_ prefix. 미설정 시 팝업이 승인키
# 오류를 표시한다.
#
# PC 는 addrlink/addrLinkUrl.do, 모바일/태블릿은 addrlink/addrMobileLinkUrl.do 를
# 쓴다(공식 jusoPopup.jsp 샘플 기준, 같은 addrlink 패밀리). 모바일 팝업용 승인키는
# 아래 NEXT_PUBLIC_JUSO_POPUP_MOBILE_KEY 로 분리한다(juso 콘솔 도메인 등록 키).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_JUSO_POPUP_KEY=
NEXT_PUBLIC_JUSO_POPUP_MOBILE_KEY=

# -----------------------------------------------------------------------------
# AUTH redirects — CMP-557 / CMP-558 / ADR-0003.
#
# Canonical location is apps/api/.env.example (API owns the OAuth callback and
# performs the 302 to these URLs). The web copy below is a browser-exposed
# SPA-side aid for building local links and showing the success/failure landing
# routes — when values disagree, apps/api/.env.example wins. Keep them in sync
# per environment.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FRONTEND_AUTH_SUCCESS_URL=/auth/success
NEXT_PUBLIC_FRONTEND_AUTH_FAILURE_URL=/auth/failure

# Proxy 가드(`apps/web/proxy.ts`, Next.js 16)가 확인하는 세션 쿠키 이름. 기본값 `jippin_session`.
# 백엔드(`apps/api`) 의 `AUTH_COOKIE_NAME` 과 항상 동일하게 유지한다 (CMP-562 / CMP-564 / CMP-571).
# AUTH_COOKIE_NAME=jippin_session

# -----------------------------------------------------------------------------
# Supabase Auth — runbook docs/runbooks/supabase-web-auth.md §3 / CMP-580.
#
# SSR cookie adapter (`apps/web/lib/supabase/{server,proxy}.ts`) 와
# OAuth 진입 BFF (`apps/web/app/auth/oauth/start/route.ts`) 가 본 두 변수를 읽는다.
# 미설정 시 SSR / 라우트 핸들러가 즉시 throw — fallback 없음.
# `NEXT_PUBLIC_SUPABASE_URL` 은 `/auth/redirect` open-redirect 가드의 origin
# allow-list SSOT 이기도 하며, Next client bundle 에 bake 되므로 build/runtime
# 환경에 모두 주입되어야 한다.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-publishable-key>

# OAuth flow-cookie HMAC secret. Generate a random high-entropy value per environment.
# Required by `/auth/oauth/start`; never expose the real value in code, issues, or PR text.
SUPABASE_FLOW_COOKIE_SECRET=<random-flow-cookie-secret>

# (선택) Supabase 콘솔 redirect allow list 와 일치하는 절대 URL. 미설정 시 BFF 가
# `new URL('/auth/callback', request.nextUrl.origin)` 로 합성한다. Vercel preview
# 처럼 origin 이 동적인 환경에서만 명시.
# NEXT_PUBLIC_FRONTEND_AUTH_CALLBACK_URL=https://www.jippin.com/auth/callback

# -----------------------------------------------------------------------------
# SUPABASE OAuth provider id mapping — CMP-581 round-11 item 3 / runbook §4.2.3 / §8.
#
# Supabase 콘솔에 Kakao 를 등록한 방식에 따라 SDK 호출 시 사용할 provider id 가
# 달라진다. **SDK provider id 와 Supabase 콘솔 등록 id 가 1:1 로 정확히 일치** 해야
# 한다 (`provider_not_enabled` 회귀 방지). `apps/web/lib/oauth-providers.ts` 의
# `resolveKakaoProviderId` 가 본 변수를 읽어 단일 export 로 SDK/BFF/audit helper
# 에 공급한다.
#
# 허용 값:
#   - 'kakao'        — Supabase 콘솔: Authentication → Providers → Kakao (native).
#   - 'custom:kakao' — Supabase 콘솔: Authentication → Providers → Custom OIDC,
#                      identifier 필드 = 'kakao' (§4.2.3 콘솔 identifier 일치 봉인).
#
# 환경변수 미지정 시 코드 fallback 은 'kakao'. 콘솔이 Custom 으로 등록되었는데
# 본 변수를 잊은 채 라이브 진입하면 §4.2.4 의 `provider_not_enabled` Sentry alert
# 가 떨어진다 — silent fail 없음.
# NEXT_PUBLIC_SUPABASE_KAKAO_PROVIDER_ID=kakao

# Kakao REST API key / client secret 등 provider 시크릿은 **Supabase 콘솔이 단독
# 보유** (콘솔의 Client ID / Client Secret 필드). web 어댑터는 직접 사용하지 않으며
# (`apps/web/lib/oauth-providers.ts` docstring 봉인), backend 가 Kakao OpenAPI 를
# 직접 호출해야 하는 경우 `apps/api/.env.example` 의 KAKAO_REST_API_KEY /
# KAKAO_CLIENT_SECRET 변수만 사용한다. 명명은 Supabase 콘솔 화면의 'Client ID' /
# 'Client Secret' 라벨과 1:1 대응 — 본 매핑은 runbook §8 콘솔 트랙이 SSOT.

# Kakao Sync audit endpoint feature gate (round-12 항목 5).
# backend `apps/api` 의 POST /auth/terms/kakao-sync 라우트가 ship 된 환경에서만
# 'true' 로 설정. 미지정/'false' 면 `apps/web/lib/kakao-sync-audit.ts` 가 호출
# 자체를 hard-fail 시켜 silent no-op (success 페이지로 잘못 진입) 회귀를 막는다.
# Default 는 'false' — backend 가 endpoint 를 ship 한 뒤 callsite (callback
# Route Handler) 가 본 값을 직접 확인 후 audit helper 의 enabled:true 로 전달.
# NEXT_PUBLIC_KAKAO_SYNC_AUDIT_ENABLED=false
