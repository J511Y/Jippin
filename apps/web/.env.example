# apps/web 환경변수 예시 (커밋 금지: 실제 값은 .env.local 또는 운영 시크릿 매니저)
# ADR-0001 §9 / AGENTS.md §4.4 봉인.

# 백엔드 API 베이스 URL (브라우저에서 직접 호출하므로 NEXT_PUBLIC_ prefix).
# 로컬 docker-compose: http://localhost:8000
# 프리뷰/운영: 배포 환경별 URL로 치환.
#
# ⚠ Docker compose 환경에서는 본 var 가 **서버 간 통신용 내부 host (예: http://api:8000)** 로
# 설정될 수 있다. 그 경우 브라우저는 도달 불가하므로, OAuth 진입 BFF 처럼 302 Location 에
# 사용되는 경로는 아래 `API_PUBLIC_BASE_URL` 을 별도로 봉인해야 한다 (CMP-584 round-3).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# **Browser-reachable** 백엔드 API 베이스 URL (server-only, NEXT_PUBLIC_ prefix 없음).
# `/auth/oauth/start` 같은 BFF 가 302 `Location` 으로 사용자를 보내는 경로는 본 var 를
# 우선 사용한다 — `apps/web/lib/api-base-url.ts::publicApiBaseUrl()` 이 단일 SSOT.
# 로컬: http://localhost:8000 (기본 fallback).
# 운영/프리뷰: 외부 도달 가능한 public URL (예: https://api.jippin.com).
# 본 값을 Docker 내부 hostname (api:, web:, app:) 으로 설정하면 publicApiBaseUrl() 가 throw.
# API_PUBLIC_BASE_URL=https://api.jippin.example

# 옵션: 클라이언트 로깅 레벨 (debug | info | warn | error).
NEXT_PUBLIC_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# AUTH redirects — CMP-557 / CMP-558 / ADR-0003 / CMP-577 (Supabase 전환).
#
# Canonical location is apps/api/.env.example (API owns the OAuth callback and
# performs the 302 to these URLs). The web copy below is a browser-exposed
# SPA-side aid for building local links and showing the success/failure landing
# routes — when values disagree, apps/api/.env.example wins. Keep them in sync
# per environment.
#
# ⚠ CMP-577 후 변경된 사용 방식:
#   - SUCCESS_URL 은 더 이상 `signInWithOAuth({ redirectTo })` 의 직접 인자가
#     아니다. `redirectTo` 는 항상 `/auth/callback?next=<SUCCESS_URL>` 절대 URL
#     이며, callback Route Handler 가 `exchangeCodeForSession` 후 `next` 로 302.
#   - Supabase 콘솔 redirect allow list 에는 `/auth/callback` 만 등록한다.
#   - FAILURE_URL 은 callback 이 `exchangeCodeForSession` / OAuth error 시 302
#     하는 최종 목적지. allow list 등록 불필요.
#   상세: `docs/runbooks/supabase-web-auth.md` §4.7.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FRONTEND_AUTH_SUCCESS_URL=/auth/success
NEXT_PUBLIC_FRONTEND_AUTH_FAILURE_URL=/auth/failure

# Optional. Vercel preview 처럼 origin 이 동적인 환경에서만 명시 봉인. 미설정 시
# 코드가 `new URL('/auth/callback', window.location.origin)` 로 합성한다.
# Supabase 콘솔 redirect allow list 에도 동일한 값을 등록해야 한다.
# NEXT_PUBLIC_FRONTEND_AUTH_CALLBACK_URL=

# Proxy 가드(`apps/web/proxy.ts`, Next.js 16)가 확인하는 세션 쿠키 이름. 기본값 `jippin_session`.
# 백엔드(`apps/api`) 의 `AUTH_COOKIE_NAME` 과 항상 동일하게 유지한다 (CMP-562 / CMP-564 / CMP-571).
# AUTH_COOKIE_NAME=jippin_session
# -----------------------------------------------------------------------------
# ⚠ 전환 안내 (CMP-577 / `docs/runbooks/supabase-web-auth.md` §9 Phase 표).
# 위 `AUTH_COOKIE_NAME` 은 자체 세션 쿠키 기반 가드용이며, **Phase 1 dual-write 동안**
# 은 ADR-0003 §2 정본 호환을 위해 라인을 주석으로 유지한다. **Phase 2** (ADR-0004
# Accepted 후) 에 `proxy.ts` 의 Supabase 전환 PR 과 함께 본 라인을 제거한다.
# Supabase 가 발급하는 자체 쿠키(`sb-<project-ref>-auth-token`)를 `proxy.ts` 가
# 직접 읽기 시작하면 별도 이름 봉인이 필요 없다.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Supabase Auth — CMP-577 / ADR-0003 §2.2.
#
# 본 변수들은 *이름과 노출 정책만* 봉인한다. 실제 값은 `.env.local` 또는 운영
# 시크릿 매니저에 보관하며, 절대 본 파일에 기재하지 않는다.
# 콘솔 세팅 / Custom Provider 등록 / Identity Linking = manual 설정은 후속
# Supabase 콘솔 트랙이 수행한다.
#
#   NEXT_PUBLIC_*  : 브라우저 번들에 포함된다. anon (publishable) key 까지만 둔다.
#   service_role key 는 본 파일에 절대 두지 않으며 `apps/api/.env.example` 이 정본.
# -----------------------------------------------------------------------------
# Supabase project URL — 형식: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon (publishable) key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
