# 집핀(Jippin) — 환경변수 예시 파일
# AGENTS.md §4.4 / CEO 브리프 §5.1 / ADR-0001 §9 봉인.
#
# 사용법:
#   cp .env.example .env
#   각 값을 실제 자격증명/URL로 채운다.
#
# 절대 금지:
#   - 본 파일에는 **실제 값**을 절대 적지 않는다. (예시값/형식만)
#   - 실제 `.env`는 `.gitignore` 가 차단한다.
#
# 시크릿 매니저 사용 권장 (운영). 로컬은 .env, CI/CD는 GitHub Actions Secrets.

# =============================================================================
# 1. 공통 — 런타임 모드
# =============================================================================
# 값: development | staging | production
APP_ENV=development
# 값: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# request_id 미들웨어 헤더명 (AGENTS.md §4.5)
REQUEST_ID_HEADER=x-request-id

# =============================================================================
# 2. Supabase Postgres (AGENTS.md §4.4 / ADR-0004)
# - DATABASE_URL      : non-pooler. 마이그레이션·롱 트랜잭션.
# - DATABASE_POOL_URL : pooler.     FastAPI 일반 쿼리 (서버리스/짧은 연결).
# - 비밀번호는 평문 커밋 금지. 운영은 시크릿 매니저.
# - APP_ENV ↔ Supabase branch 매핑은 환경별 URL 값으로만 한다.
#   자세한 매핑: docs/runbooks/supabase-branching.md.
# =============================================================================
DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_POOL_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
# Alembic은 historical reference only. 신규 forward migration은 supabase/migrations/*.sql 에 작성한다.
DATABASE_SYNC_URL=

# =============================================================================
# 3. Redis 7.4 (ADR-0001 §5)
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru

# =============================================================================
# 4. Cloudflare R2 — 객체 스토리지 (ADR-0001 §6)
# - S3 호환. endpoint_url은 R2 계정별 도메인.
# - 버킷 분리: floorplans-raw / floorplans-masked / overlays / reports
# =============================================================================
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_ENDPOINT_URL=https://REPLACE_ME.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_FLOORPLANS_RAW=jippin-floorplans-raw
R2_BUCKET_FLOORPLANS_MASKED=jippin-floorplans-masked
R2_BUCKET_OVERLAYS=jippin-overlays
R2_BUCKET_REPORTS=jippin-reports

# =============================================================================
# 5. OAuth — 소셜 로그인 (FR-AUTH-001 / SDD §6.1)
# - 카카오 / 구글 / 네이버. 자체 비밀번호 금지.
# =============================================================================
KAKAO_REST_API_KEY=REPLACE_ME
KAKAO_CLIENT_SECRET=REPLACE_ME
KAKAO_REDIRECT_URI=http://localhost:8000/auth/callback/kakao

GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/google

NAVER_OAUTH_CLIENT_ID=REPLACE_ME
NAVER_OAUTH_CLIENT_SECRET=REPLACE_ME
NAVER_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/naver

OAUTH_STATE_REDIS_URL=redis://redis:6379/1
OAUTH_STATE_TTL_SECONDS=600
AUTH_OAUTH_STATE_TTL_SECONDS=600
ANON_SESSION_HEADER=x-jippin-anon-id

FRONTEND_AUTH_SUCCESS_URL=http://localhost:3000/auth/success
FRONTEND_AUTH_FAILURE_URL=http://localhost:3000/auth/failure
FRONTEND_AUTH_TERMS_URL=http://localhost:3000/auth/terms

# =============================================================================
# 6. JWT — 세션 토큰 (AGENTS.md §4.4)
# - 256bit 이상 random secret. openssl rand -base64 48
# =============================================================================
AUTH_JWT_SECRET=REPLACE_ME_WITH_RANDOM_256BIT_SECRET
AUTH_JWT_ALG=HS256
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_JWT_REFRESH_TTL_SECONDS=604800
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_NAME=jippin_session
# 운영 도메인에서만 설정. 로컬은 비움.
AUTH_COOKIE_DOMAIN=
# 비움이면 APP_ENV=production 에서만 Secure=true.
AUTH_COOKIE_SECURE=
KAKAO_SYNC_REQUIRED_TERM_TAGS=service_terms,privacy_policy

# =============================================================================
# 7. OpenAI VLM (ADR-0001 §7 T6)
# - 기본:  gpt-5.4-mini  / 정밀: gpt-5.5
# =============================================================================
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VLM_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_VLM_MODEL_PRECISE=gpt-5.5
OPENAI_TIMEOUT_SECONDS=30

# =============================================================================
# 8. AI 모델 / Mask2Former + SAM2 (ADR-0001 §7 T6)
# - 로컬 캐시 경로 / fine-tune 모델 ID.
# =============================================================================
HF_HOME=./.cache/huggingface
MASK2FORMER_MODEL_ID=facebook/mask2former-swin-large-coco-panoptic
SAM2_MODEL_ID=facebook/sam2-hiera-large
TORCH_DEVICE=cpu

# =============================================================================
# 9. 애플리케이션 레벨 암호화 (CEO 브리프 §5 / NFR-SEC)
# - leads.contact_info 등 PII 컬럼 AES-256 암호화 키.
# =============================================================================
APP_ENCRYPTION_KEY=REPLACE_ME_WITH_RANDOM_AES_256_KEY_BASE64

# =============================================================================
# 10. 알림 — 관리자 리드 통보 (FR-REPORT-011)
# =============================================================================
ADMIN_NOTIFY_EMAIL=admin@jippin.example
ADMIN_NOTIFY_SMS=+821000000000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME

# =============================================================================
# 11. 프론트엔드 — 공개 변수 (NEXT_PUBLIC_*)
# - 브라우저로 노출되는 값만. 시크릿 금지.
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-publishable-key>
SUPABASE_FLOW_COOKIE_SECRET=REPLACE_ME_WITH_RANDOM_FLOW_COOKIE_SECRET
SUPABASE_JWT_SECRET=REPLACE_ME_WITH_SUPABASE_JWT_SECRET
SUPABASE_JWT_AUDIENCE=authenticated
NEXT_PUBLIC_APP_NAME=집핀
NEXT_PUBLIC_LEGAL_NOTICE_VERSION=1.0
