# =============================================================================
# Jippin 모노레포 루트 .gitignore
# AGENTS.md §4.4 — 시크릿은 절대 커밋하지 않는다.
# =============================================================================

# --- 시크릿 / 환경변수 -------------------------------------------------------
.env
.env.local
.env.*.local
infra/compose/.env
# .example 파일은 트래킹한다 (자리표시자만 담는다).
!.env.example
!**/.env.example

# --- 자동 머지되는 compose 오버레이 (개발자가 cp 해서 활성화. 커밋 금지) -----
infra/compose/docker-compose.override.yml

# --- Node / pnpm -------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-error.log*

# --- Next.js -----------------------------------------------------------------
.next/
out/
build/

# --- Python ------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- IDE / OS ----------------------------------------------------------------
.idea/
.vscode/
*.swp
Thumbs.db
.DS_Store

# --- 임시 / 작업물 -----------------------------------------------------------
.tmp/
*.log
coverage/
dist/

# --- Terraform (CMP-532 후속) ------------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
crash.log
