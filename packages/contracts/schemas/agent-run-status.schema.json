{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jippin.local/contracts/agent-run-status.schema.json",
  "title": "AgentRunStatus",
  "description": "agent_runs row 의 클라이언트 노출 투영. `GET /sessions/{session_id}/agent/runs/{run_id}` 정본. 재연결 시 재스트림 없이 상태를 확인하는 데 쓴다.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "session_id",
    "thread_id",
    "status",
    "model",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "1.0.0",
      "description": "스키마 버전 (semver)."
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "agent_runs.id."
    },
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "소유 세션 id."
    },
    "thread_id": {
      "type": "string",
      "format": "uuid",
      "description": "LangGraph 체크포인터 thread_id (= session_id)."
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "awaiting_input",
        "interrupted",
        "succeeded",
        "failed",
        "cancelled"
      ],
      "description": "런 상태 머신."
    },
    "model": {
      "type": "string",
      "description": "이 런에 사용된 LLM 모델 식별자 (예: openai:gpt-5.4-mini)."
    },
    "current_step": {
      "type": ["string", "null"],
      "description": "마지막으로 진입한 플로우 단계 라벨."
    },
    "langsmith_run_url": {
      "type": ["string", "null"],
      "description": "LangSmith 트레이스 URL (있으면)."
    },
    "error_code": {
      "type": ["string", "null"],
      "description": "실패 시 안정적 에러 코드."
    },
    "error_message": {
      "type": ["string", "null"],
      "description": "실패 시 사람이 읽을 수 있는 짧은 메시지 (원본 payload·PII 비포함)."
    },
    "started_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "런 시작 시각."
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "런 종료 시각."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "row 생성 시각."
    }
  }
}
