{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jippin.local/contracts/agent-sse-event.schema.json",
  "title": "AgentSseEvent",
  "description": "에이전트 런 SSE 스트림의 단일 이벤트 envelope. SSE `event:` 필드가 type, `data:` 필드가 본 JSON 이다. type 별 discriminated union — 클라이언트는 type 으로 분기한다.",
  "oneOf": [
    { "$ref": "#/$defs/TokenEvent" },
    { "$ref": "#/$defs/ToolStepEvent" },
    { "$ref": "#/$defs/StateChangeEvent" },
    { "$ref": "#/$defs/MessageEvent" },
    { "$ref": "#/$defs/ErrorEvent" },
    { "$ref": "#/$defs/DoneEvent" }
  ],
  "$defs": {
    "ToolStepStatus": {
      "type": "string",
      "enum": ["started", "succeeded", "failed"],
      "description": "도구 라이프사이클 상태. 패키지 루트의 Status 충돌을 피해 고유 이름."
    },
    "TokenEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "delta"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "token" },
        "seq": { "type": "integer", "minimum": 0, "description": "런 내 단조 증가 시퀀스." },
        "delta": { "type": "string", "description": "assistant 응답의 토큰 조각. 누적은 클라이언트가 한다." }
      },
      "description": "LLM 토큰 스트리밍 조각. 영속화되지 않으며 최종 message 이벤트만 저장된다."
    },
    "ToolStepEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "tool_name", "tool_kind", "status"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "tool_step" },
        "seq": { "type": "integer", "minimum": 0 },
        "tool_name": { "type": "string", "minLength": 1, "description": "실행 중/완료된 도구 이름." },
        "tool_kind": {
          "type": "string",
          "enum": [
            "retrieval",
            "db_query",
            "external_api",
            "ai_model",
            "rule_engine",
            "render",
            "notification",
            "other"
          ],
          "description": "도구 분류 (chat_tool_calls.tool_kind 와 정합)."
        },
        "status": {
          "$ref": "#/$defs/ToolStepStatus",
          "description": "도구 라이프사이클 상태."
        },
        "summary": { "type": ["string", "null"], "description": "사용자 노출용 짧은 진행 요약." },
        "error_code": { "type": ["string", "null"], "description": "status=failed 시 안정적 에러 코드." }
      },
      "description": "도구 호출 진행 상황. 원장(chat_tool_calls) 의 사용자 친화 투영."
    },
    "StateChangeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "session_status"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "state_change" },
        "seq": { "type": "integer", "minimum": 0 },
        "session_status": {
          "type": "string",
          "enum": [
            "draft",
            "address_ready",
            "floorplan_selected",
            "analyzing",
            "awaiting_overlay",
            "collecting_info",
            "ready_for_rule",
            "report_ready",
            "handoff",
            "expired",
            "deleted"
          ],
          "description": "세션 상태 머신의 새 상태."
        },
        "completion_decision": {
          "type": ["string", "null"],
          "enum": ["ASK_MORE", "REQUEST_OVERLAY_REVIEW", "PROCEED_RULE", "HOLD_OR_HANDOFF", null],
          "description": "FLOW_GUARD 결정 (completion-decision 계약의 decision enum 재사용)."
        }
      },
      "description": "세션 status / completion_decision 전이 알림."
    },
    "MessageEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "role", "content"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "message" },
        "seq": { "type": "integer", "minimum": 0 },
        "role": {
          "type": "string",
          "enum": ["assistant", "system", "tool"],
          "description": "런타임이 만든 메시지 role."
        },
        "content": { "type": "string", "description": "완료된 메시지 본문." },
        "message_id": { "type": ["string", "null"], "format": "uuid", "description": "영속화된 chat_messages.id." },
        "ui_components": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true },
          "description": "A2UI 렌더링 payload (chat_messages.ui_components 와 정합)."
        }
      },
      "description": "완료된 메시지 (영속화 후 전송)."
    },
    "ErrorEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "error_code", "message", "recoverable"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "error" },
        "seq": { "type": "integer", "minimum": 0 },
        "error_code": { "type": "string", "description": "안정적 에러 코드." },
        "message": { "type": "string", "description": "사람이 읽을 수 있는 짧은 메시지." },
        "recoverable": {
          "type": "boolean",
          "description": "true 면 스트림이 계속될 수 있고, false 면 done 이 뒤따른다."
        }
      },
      "description": "런 중 발생한 오류."
    },
    "DoneEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "seq", "run_status"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "type": { "type": "string", "const": "done" },
        "seq": { "type": "integer", "minimum": 0 },
        "run_status": {
          "type": "string",
          "enum": ["succeeded", "failed", "awaiting_input", "interrupted", "cancelled"],
          "description": "런 종료 상태. awaiting_input/interrupted 는 resume 가능."
        }
      },
      "description": "스트림 종료 신호. 항상 마지막 이벤트."
    }
  }
}
