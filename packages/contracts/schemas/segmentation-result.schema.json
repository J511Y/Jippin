{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jippin.local/contracts/segmentation-result.schema.json",
  "title": "SegmentationResult",
  "description": "평면도 세그멘테이션 도구(HuggingFace Inference Endpoint) 의 구조화 결과. 도구는 절대 raise 하지 않고 본 형태를 반환한다 — 엔드포인트 미배포/콜드스타트/타임아웃도 ok=false 로 표현된다. 1.2.0: 오버레이 렌더용 image + regions(좌표) 추가(추가형, 하위호환).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ok"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "1.2.0",
      "description": "스키마 버전 (semver). 1.2.0: image/regions(오버레이 좌표) 추가. 1.1.0: error_code 에 NO_IMAGE/NOT_SCANNED 추가."
    },
    "ok": {
      "type": "boolean",
      "description": "추론 성공 여부. false 면 error_code 가 채워지고 에이전트는 degrade 한다."
    },
    "error_code": {
      "type": ["string", "null"],
      "enum": [
        "SEGMENTATION_ENDPOINT_UNAVAILABLE",
        "SEGMENTATION_COLD_START_TIMEOUT",
        "SEGMENTATION_TIMEOUT",
        "SEGMENTATION_UPSTREAM_ERROR",
        "SEGMENTATION_BAD_REQUEST",
        "SEGMENTATION_BAD_RESPONSE",
        "SEGMENTATION_NO_IMAGE",
        "SEGMENTATION_NOT_SCANNED",
        null
      ],
      "description": "ok=false 시 안정적 에러 코드. 미배포/DNS/404=ENDPOINT_UNAVAILABLE, 503=COLD_START_TIMEOUT, 세션에 도면 미업로드=NO_IMAGE 등."
    },
    "mask_asset_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "저장된 segmentation_mask floorplan_assets.id (있으면). 마스크 이미지는 Storage 에만 두고 여기엔 포인터만."
    },
    "instances": {
      "type": "array",
      "items": { "$ref": "#/$defs/Instance" },
      "description": "검출된 인스턴스 요약 목록(라벨별 집계). 좌표는 포함하지 않는다 — 에이전트 추론/룰 입력용 경량 요약."
    },
    "image": {
      "anyOf": [{ "$ref": "#/$defs/Image" }, { "type": "null" }],
      "description": "원본 이미지 픽셀 크기. regions 의 polygon/bbox 가 이 좌표계(원본 픽셀)다 — 오버레이가 표시 크기로 스케일할 때 쓴다."
    },
    "regions": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/Region" },
      "description": "오버레이 렌더용 per-region 검출 결과(폴리곤/클래스/신뢰도). LLM 컨텍스트엔 싣지 않고 프론트 오버레이 카드로만 전달한다(대용량)."
    },
    "summary": {
      "type": ["string", "null"],
      "description": "사람이 읽을 수 있는 짧은 요약 (예: '내력벽 후보 3, 비내력벽 후보 5')."
    }
  },
  "$defs": {
    "Label": {
      "type": "string",
      "enum": [
        "door",
        "window",
        "wall_reinforced_concrete",
        "wall_other",
        "wall_unknown",
        "space_multipurpose",
        "space_elevator_hall",
        "space_stairwell",
        "space_living_room",
        "space_bedroom",
        "space_kitchen",
        "space_entrance",
        "space_balcony",
        "space_bathroom",
        "space_ac_room",
        "space_dress_room",
        "space_other",
        "space_elevator"
      ],
      "description": "모델 클래스 라벨. STR 5 + SPA 13 (floor-plan-model-train / cmp180_full 정합)."
    },
    "Instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "count"],
      "properties": {
        "label": { "$ref": "#/$defs/Label" },
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "해당 라벨 인스턴스 수."
        },
        "mean_confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "평균 신뢰도."
        }
      }
    },
    "Image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "원본 이미지 가로 픽셀."
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "description": "원본 이미지 세로 픽셀."
        }
      }
    },
    "Region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region_id", "class_name", "polygon"],
      "properties": {
        "region_id": {
          "type": "string",
          "description": "응답 내 안정 ID (예: 'pred:1'). 사용자 벽 선택(selected_walls)의 키가 된다."
        },
        "class_name": { "$ref": "#/$defs/Label" },
        "score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "모델 신뢰도."
        },
        "polygon": {
          "type": "array",
          "items": { "type": "number" },
          "description": "원본 픽셀 좌표의 평면 배열 [x1, y1, x2, y2, ...]."
        },
        "bbox": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "description": "[x, y, width, height] (원본 픽셀)."
        },
        "requires_hitl": {
          "type": "boolean",
          "description": "사람 검토 필요 여부(벽 클래스=true). 확정 판정 아님 — '후보/검토 필요'로만 표시."
        }
      }
    }
  }
}
